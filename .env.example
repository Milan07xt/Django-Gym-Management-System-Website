# Copy this file to .env and fill in your values before deploying.

# Django secret key – generate a new one for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Example: ALLOWED_HOSTS=mygymapp.up.railway.app
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL database URL (Railway provides this automatically as DATABASE_URL)
# Format: postgres://user:password@host:port/dbname
# Leave empty to use SQLite locally (do NOT set this locally)
DATABASE_URL=
